local function updateConsole()
    local text = ""
    local numText = ""
    
    for i, msg in ipairs(logs) do
        text = text .. msg .. "\n"
        numText = numText .. tostring(i) .. "\n"
    end
    
    ConsoleBox.Text = text
    ConsoleNumbers.Text = numText
    
