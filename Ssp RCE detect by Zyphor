    ConsoleScroll.CanvasSize = UDim2.new(0,0,0,ConsoleBox.TextBounds.Y + 10)
    ConsoleScroll.CanvasPosition = Vector2.new(0, math.max(0, ConsoleBox.TextBounds.Y - ConsoleScroll.AbsoluteWindowSize.Y))
end


